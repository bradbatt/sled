{
  "name": "my-app",
  "type": "module",
  "scripts": {
    "start": "wrangler dev --persist-to .wrangler/state",
    "dev": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test:app": "WRANGLER_LOG_PATH=.wrangler/logs/wrangler.log pnpm exec vitest run",
    "test": "pnpm run test:app",
    "knip": "knip",
    "jscpd": "jscpd"
  },
  "dependencies": {
    "hono": "^4.12.3",
    "marked": "^17.0.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.14",
    "@types/node": "^24.11.0",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0"
  }
}
